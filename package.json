{
  "name": "cursa-ai-quest",
  "version": "1.0.0",
  "description": "QuestPro - Gerador de simulados com IA (Gemini) para concursos",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js"
  },
  "engines": {
    "node": "^20.0.0"
  },
  "dependencies": {
    "express": "^4.19.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "vercel": {
    "rewrites": [
      {
        "source": "/api/(.*)",
        "destination": "/server.js"
      },
      {
        "source": "/(.*)",
        "destination": "/src/index.html"
      }
    ]
  }
}

